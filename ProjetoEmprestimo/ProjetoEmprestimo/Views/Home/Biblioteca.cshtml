@model IEnumerable<ProjetoEmprestimo.Models.Livro>

@{
    ViewData["Title"] = "Biblioteca";
}

<h1>Biblioteca1</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.codLivro)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.nomeLivro)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.imagemLivro)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.quantidade)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <div class="col-lg-3 col-md-6 mb-4" style="margin:2% 4%;">
                <div class="card h-100">

                    @if (item.imagemLivro != null)
                    {
                        <img class="card-img-right flex-auto d-none d-md-block"
                             data-src="holder.js/300x200"
                             alt="Thumbnail [300x200]"
                             style="width: 300px; height: 300px;"
                             src="@item.imagemLivro"
                             data-holder-rendered="true">
                    }
                    else
                    {
                        <img class="card-img-right flex-auto d-none d-md-block"
                             data-src="holder.js/300x200"
                             alt="Thumbnail [300x200]"
                             style="width: 300px; height: 300px;"
                             src="/images/image-not-found.jpg"
                             data-holder-rendered="true">
                    }

                    <div class="card-body">
                        <h4 class="card-title">
                            @Html.DisplayFor(modelItem => item.nomeLivro)
                        </h4>
                        <p class="card-text">Código: @item.codLivro</p>
                    </div>

                    <div class="card-footer space-between-flex" style="width: 90%">
                        @using (Html.BeginForm("AdicionarItem", "Home", FormMethod.Post))
                        {
                            <input type="hidden" name="id" value="@item.codLivro" />
                            <input type="hidden" name="quantidade" value="1" />
                            <button type="submit" class="btn btn-default btn-acao-primario">
                                Adicionar
                            </button>
                        }
                    </div>

                </div>
            </div>
        }
    </div>
</div>
</div>
}
